# LLM -- all calls go through OpenRouter (one key, routes to any provider)
OPENROUTER_API_KEY=
PRIMARY_MODEL=z-ai/glm-5.2
FALLBACK_MODEL=anthropic/claude-sonnet-5

# TTS -- Sarvam (multilingual, Indic languages incl. Bengali)
SARVAM_API_KEY=

# Observability
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=conceptreel

# Pipeline tuning
MAX_REPL_ITERATIONS=3
MAX_FIX_CALLS_PER_JOB=12

# Frontend -> backend
# BACKEND_URL: used for Streamlit's own server-side HTTP calls (job polling). In Docker this is
# the internal service hostname (http://backend:8000); running locally without Docker, both are
# just http://localhost:8000.
# PUBLIC_BACKEND_URL: embedded in the <video> tag src, must be reachable from the user's browser.
BACKEND_URL=http://localhost:8000
PUBLIC_BACKEND_URL=http://localhost:8000
